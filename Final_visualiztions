# -----------------------------------------------------------------------------
# 1. Load Required Libraries
# -----------------------------------------------------------------------------

library(tidyverse)
library(scales)
library(knitr)
library(forcats)


# -----------------------------------------------------------------------------
# 2. Design Standards
# -----------------------------------------------------------------------------

mushroom_colors <- c(
  "edible" = "#9FE3B5",     # Green represents edible/safe mushrooms.
  "poisonous" = "#9C6ADE"  # Purple represents poisonous mushrooms.
)

mushroom_theme <- theme_minimal(base_size = 12) +
  theme(
    plot.title = element_text(face = "bold", size = 15),
    plot.subtitle = element_text(size = 11),
    axis.title = element_text(size = 11),
    legend.title = element_text(face = "bold"),
    legend.position = "right",
    panel.grid.minor = element_blank()
  )

# -----------------------------------------------------------------------------
# 3. Summary Statistics and Patterns
# -----------------------------------------------------------------------------

# Overall class distribution
class_summary <- data_clean |>
  count(classes) |>
  mutate(proportion = n / sum(n))

# Odor vs. class
odor_summary <- data_clean |>
  count(odor, classes) |>
  group_by(odor) |>
  mutate(proportion = n / sum(n)) |>
  ungroup()

# Gill color vs. class
gill_color_summary <- data_clean |>
  count(`gill-color`, classes) |>
  group_by(`gill-color`) |>
  mutate(proportion = n / sum(n)) |>
  ungroup()

# Bruises vs. class
bruises_summary <- data_clean |>
  count(`bruises?`, classes) |>
  group_by(`bruises?`) |>
  mutate(proportion = n / sum(n)) |>
  ungroup()

# Spore print color vs. class
spore_summary <- data_clean |>
  count(`spore-print-color`, classes) |>
  group_by(`spore-print-color`) |>
  mutate(proportion = n / sum(n)) |>
  ungroup()

# Print summaries for quick review
print(class_summary)
print(odor_summary)
print(gill_color_summary)
print(bruises_summary)
print(spore_summary)

# -----------------------------------------------------------------------------
# 4. Professional Tables
# -----------------------------------------------------------------------------

# Table 1: Overall Distribution
class_table <- data_clean |>
  count(classes) |>
  mutate(Percentage = n / sum(n) * 100) |>
  rename(Classification = classes, Count = n)

kable(
  class_table,
  digits = 1,
  caption = "Table 1: Distribution of Edible vs. Poisonous Mushrooms"
)

# Table 2: Odor Toxicity
odor_table <- data_clean |>
  count(odor, classes) |>
  group_by(odor) |>
  mutate(Toxicity_Rate = n / sum(n)) |>
  ungroup() |>
  filter(classes == "poisonous") |>
  select(
    Odor = odor,
    `Poisonous Count` = n,
    `Toxicity Rate` = Toxicity_Rate
  ) |>
  arrange(desc(`Toxicity Rate`))

kable(
  odor_table,
  digits = 2,
  caption = "Table 2: Mushroom Toxicity Based on Odor"
)

# Table 3: Gill Color Toxicity

gill_table <- data_clean |>
  count(`gill-color`, classes) |>
  group_by(`gill-color`) |>
  mutate(Rate = n / sum(n)) |>
  ungroup() |>
  filter(classes == "poisonous") |>
  select(
    `Gill Color` = `gill-color`,
    `Poisonous Count` = n,
    `Toxicity Rate` = Rate
  ) |>
  arrange(desc(`Toxicity Rate`))

kable(
  gill_table,
  digits = 2,
  caption = "Table 3: Toxicity Rate by Gill Color"
)

# Table 4: Bruising Toxicity
bruise_table <- data_clean |>
  count(`bruises?`, classes) |>
  group_by(`bruises?`) |>
  mutate(Rate = n / sum(n)) |>
  ungroup() |>
  filter(classes == "poisonous") |>
  select(
    Bruises = `bruises?`,
    `Poisonous Count` = n,
    `Toxicity Rate` = Rate
  )

kable(
  bruise_table,
  digits = 2,
  caption = "Table 4: Probability of Toxicity Based on Bruising"
)

# Table 5: Spore Print Color Toxicity
spore_table <- data_clean |>
  count(`spore-print-color`, classes) |>
  group_by(`spore-print-color`) |>
  mutate(Rate = n / sum(n)) |>
  ungroup() |>
  filter(classes == "poisonous") |>
  select(
    `Spore Print Color` = `spore-print-color`,
    `Poisonous Count` = n,
    `Toxicity Rate` = Rate
  ) |>
  arrange(desc(`Toxicity Rate`))

kable(
  spore_table,
  digits = 2,
  caption = "Table 5: Toxicity Rate by Spore Print Color"
)

# -----------------------------------------------------------------------------
# 5. Core Visualizations
# -----------------------------------------------------------------------------

# Visual 1: Odor Analysis, Proportion Bar Chart
# Insight: Foul and pungent odors appear strongly associated with toxicity.
ggplot(data_clean, aes(y = odor, fill = classes)) +
  geom_bar(position = "fill") +
  scale_fill_manual(values = mushroom_colors) +
  scale_x_continuous(labels = percent) +
  mushroom_theme +
  labs(
    title = "Mushroom Edibility by Odor",
    subtitle = "Foul and pungent odors are strong indicators of toxicity",
    x = "Proportion of Samples",
    y = "Odor Type",
    fill = "Class"
  )

# Visual 2: Gill Color, Grouped Bar Chart
# Insight: Some gill colors appear more often in poisonous mushrooms.
ggplot(data_clean, aes(x = `gill-color`, fill = classes)) +
  geom_bar(position = "dodge") +
  scale_fill_manual(values = mushroom_colors) +
  mushroom_theme +
  labs(
    title = "Edibility Patterns in Gill Color",
    subtitle = "Certain gill colors show higher association with toxicity",
    x = "Gill Color",
    y = "Total Count",
    fill = "Class"
  ) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

# Visual 3: Odor vs. Class, Categorical Heatmap
# Insight: Tile intensity shows where odor-class combinations are concentrated.
odor_heatmap <- data_clean |>
  count(classes, odor)

ggplot(odor_heatmap, aes(x = classes, y = odor, fill = n)) +
  geom_tile(color = "white") +
  scale_fill_gradient(low = "#9FE3B5", high = "#9C6ADE") +
  mushroom_theme +
  labs(
    title = "Heatmap: Odor Frequency by Class",
    subtitle = "Intensity shows where most samples are concentrated",
    x = "Classification",
    y = "Odor Type",
    fill = "Count"
  )

# Visual 4: Spore Print Color, Dot Plot
# Insight: Dot position shows differences in spore print color counts.
ggplot(
  data_clean |> count(`spore-print-color`, classes),
  aes(x = n, y = `spore-print-color`, color = classes)
) +
  geom_point(size = 3) +
  scale_color_manual(values = mushroom_colors) +
  mushroom_theme +
  labs(
    title = "Distribution of Mushrooms by Spore Print Color",
    subtitle = "Dot position shows count distribution",
    x = "Count",
    y = "Spore Print Color",
    color = "Class"
  )

